# Sistema de Seguimiento de Entregas - Variables de Entorno

# Ruta a la base de datos SQLite (relativa al contenedor)
NOCODB_DB_PATH=/data/noco.db

# Filtrar solo cohortes activas en el dashboard
COHORTE_FILTRAR_ACTIVAS=true

# Modo de Flask: development o production
FLASK_ENV=production

# NocoDB API (para verificación remota con verify_nocodb_schema.ps1)
# Generar token en: NocoDB → Team & Settings → API Tokens → Add New Token
# NOCODB_TOKEN=tu-api-token-aqui
# NOCODB_URL=https://nocodb.matiasbarreto.com

# URL pública de NocoDB (usada por docker-compose)
# NOCODB_PUBLIC_URL=https://nocodb.matiasbarreto.com

# Credenciales para el área docente (/resumen y exportación excel)
# Obligatorio cambiar en producción
ADMIN_USER=docente
ADMIN_PASSWORD=entregas2026

# Opcional: SMTP Gmail para notificaciones e invitaciones desde NocoDB
# Requiere una cuenta Gmail (o Google Workspace) con verificación en 2 pasos activada.
# Generar App Password en: https://myaccount.google.com/apppasswords
# GMAIL_USER=tu-email@gmail.com
# GMAIL_APP_PASSWORD=abcdefghijklmnop

# Opcional: Webhook para notificaciones (futuro)
# WEBHOOK_URL=https://hooks.slack.com/...
