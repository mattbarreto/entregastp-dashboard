# Sistema de Seguimiento de Entregas - Variables de Entorno

# Ruta a la base de datos SQLite (relativa al contenedor)
NOCODB_DB_PATH=/data/noco.db

# Filtrar solo cohortes activas en el dashboard
COHORTE_FILTRAR_ACTIVAS=true

# Modo de Flask: development o production
FLASK_ENV=production

# Opcional: Configuración de email (futuro)
# GMAIL_USER=tu-email@universidad.edu.ar
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Opcional: Webhook para notificaciones (futuro)
# WEBHOOK_URL=https://hooks.slack.com/...
